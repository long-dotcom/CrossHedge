# MT5 Gateway 只在安装 MetaTrader 5 Terminal 的 Windows 主机使用。
# 将 YOUR_SERVER_PUBLIC_IP 替换为项目服务器公网 IP；密码必须与服务器 .env 一致。
REDIS_URL=redis://YOUR_SERVER_PUBLIC_IP:6391/0
REDIS_PASSWORD=change-me-before-production

# 留空时复用 MT5 Terminal 当前已登录会话。
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

MT5_LIVE_ORDER_ENABLED=false
MT5_DEMO_ORDER_ENABLED=false
MT5_ORDER_DEVIATION_POINTS=20
MT5_ORDER_MAGIC=260620
MT5_ORDER_POLL_INTERVAL_MS=75
MT5_QUOTE_POLL_INTERVAL_MS=200
MT5_SESSION_TICK_STALE_SECONDS=120

REDIS_KEY_PREFIX=crosshedge
REDIS_SOCKET_TIMEOUT_SECONDS=5
MT5_RPC_TIMEOUT_SECONDS=15
MT5_SNAPSHOT_TTL_SECONDS=10
MT5_HEARTBEAT_TTL_SECONDS=15
