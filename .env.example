# Docker Compose 编排配置。交易所账户与业务开关请在前端管理台配置。
ENVIRONMENT=local

# 数据库仅在容器网络内访问。
POSTGRES_PASSWORD=crosshedge_local

# 只有前端对外开放；Redis 仅绑定 127.0.0.1 供本机 MT5 Gateway 使用。
APP_PORT=8080
REDIS_HOST_PORT=16379

# 容器内后端连接 Redis 的地址与密码。生产环境必须修改示例密码。
REDIS_URL=redis://redis:16379/0
REDIS_PASSWORD=change-me-before-production

# 首次管理员登录配置。生产环境必须修改默认密码。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 基础运行模式；更细的交易和账户配置由前端保存到数据库。
QUOTE_SOURCE_MODE=live
SCANNER_INTERVAL_MS=1000

# JWT_SECRET、EXCHANGE_CONFIG_SECRET 由 secrets-init 首次生成，保存在 Docker
# app_secrets 卷中；Redis 地址和密码始终使用上面的环境变量，不会随机生成。
