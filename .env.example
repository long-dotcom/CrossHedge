# Docker Compose 编排配置。交易所账户与业务开关请在前端管理台配置。
ENVIRONMENT=local

# 数据库仅在容器网络内访问。
POSTGRES_PASSWORD=crosshedge_local

# Redis 发布到服务器全部网络接口，供远程 MT5 Gateway 通过公网地址访问。
APP_PORT=8080
REDIS_BIND_ADDRESS=0.0.0.0
REDIS_HOST_PORT=6391

# 容器内后端连接 Redis 的地址与密码。生产环境必须修改示例密码。
REDIS_URL=redis://redis:6391/0
REDIS_PASSWORD=change-me-before-production

# 手动设置并长期保持不变。EXCHANGE_CONFIG_SECRET 变更后已有交易所凭据将无法解密。
JWT_SECRET=
EXCHANGE_CONFIG_SECRET=

# 首次管理员登录配置。生产环境必须修改默认密码。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 基础运行模式；更细的交易和账户配置由前端保存到数据库。
QUOTE_SOURCE_MODE=live
SCANNER_INTERVAL_MS=1000

# Redis、JWT 和交易所加密密钥均直接读取环境变量，不会自动生成。
